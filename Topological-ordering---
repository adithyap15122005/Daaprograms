#include <stdio.h>
#include <time.h>

void topologicalSort(int n, int adj[20][20])
{
    int indegree[20] = {0};
    int visited[20] = {0};
    int topo[20];
    int snapshot[20][20];
    int step = 0;

    // Calculate initial indegree
    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < n; j++)
        {
            if(adj[i][j] == 1)
                indegree[j]++;
        }
    }

    // Store initial indegree
    for(int i = 0; i < n; i++)
        snapshot[0][i] = indegree[i];

    int k = 0;

    // Topological Sort
    while(k < n)
    {
        int found = 0;

        for(int i = 0; i < n; i++)
        {
            if(indegree[i] == 0 && visited[i] == 0)
            {
                topo[k++] = i;
                visited[i] = 1;
                found = 1;

                // Delete outgoing edges
                for(int j = 0; j < n; j++)
                {
                    if(adj[i][j] == 1)
                        indegree[j]--;
                }

                step++;

                // Store updated indegrees
                for(int t = 0; t < n; t++)
                    snapshot[step][t] = indegree[t];

                break;
            }
        }

        if(!found)
        {
            printf("\nGraph contains a cycle\n");
            return;
        }
    }

    printf("\nIndegree of given nodes\n\n");

    // Print triangular indegree table
    for(int col = 0; col < n; col++)
    {
        printf("%c = ", 'A' + col);

        for(int row = 0; row <n; row++)
        {
            printf("%d ", snapshot[row][col]);
        }

        printf("\n\n");
    }

    printf("Topological Order is ");

    for(int i = 0; i < n; i++)
    {
        printf("%c ", 'A' + topo[i]);
    }

    printf("\n");
}

int main()
{
    int n;
    int adj[20][20];

    clock_t start, end;
    double cpu_time;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter Adjacency Matrix:\n");

    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < n; j++)
        {
            scanf("%d", &adj[i][j]);
        }
    }

    start = clock();

    topologicalSort(n, adj);

    end = clock();

    cpu_time = (double)(end - start) / CLOCKS_PER_SEC;

    printf("\nTime Taken = %f seconds\n", cpu_time);
    printf("Time Complexity = O(n^2)\n");

    return 0;
}
