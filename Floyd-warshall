#include <stdio.h>
#include <time.h>

#define INF 99999

void floydWarshall(int n, int dist[20][20])
{
    int i, j, k;

    for (k = 0; k < n; k++)
    {
        for (i = 0; i < n; i++)
        {
            for (j = 0; j < n; j++)
            {
                if (dist[i][k] + dist[k][j] < dist[i][j])
                {
                    dist[i][j] = dist[i][k] + dist[k][j];
                }
            }
        }
    }

    printf("\nShortest Distance Matrix:\n");

    for (i = 0; i < n; i++)
    {
        for (j = 0; j < n; j++)
        {
            if (dist[i][j] == INF)
                printf("INF ");
            else
                printf("%3d ", dist[i][j]);
        }
        printf("\n");
    }
}

int main()
{
    int n;
    int dist[20][20];

    clock_t start, end;
    double cpu_time;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");

    for (int i = 0; i < n; i++)
    {
        for (int j = 0; j < n; j++)
        {
            scanf("%d", &dist[i][j]);

            if (i != j && dist[i][j] == 0){
                dist[i][j] = INF;
            }
        }
    }

    start = clock();

    floydWarshall(n, dist);

    end = clock();

    cpu_time = (double)(end - start) / CLOCKS_PER_SEC;

    printf("\nTime Taken = %f seconds\n", cpu_time);

    printf("Time Complexity = O(n^3)\n");
    printf("Space Complexity = O(n^2)\n");

    return 0;
}
