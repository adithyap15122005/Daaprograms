#include <stdio.h>
#include <time.h>

void topologicalSort(int n, int adj[20][20])
{
    int indegree[20] = {0};
    int visited[20] = {0};
    int topo[20];
    int history[20];
    int k = 0;

    // Calculate initial indegrees
    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < n; j++)
        {
            if(adj[i][j] == 1)
                indegree[j]++;
        }
    }

    // Topological Sort and store indegree history
    while(k < n)
    {
        int found = 0;

        for(int i = 0; i < n; i++)
        {
            if(indegree[i] == 0 && visited[i] == 0)
            {
                topo[k] = i;

                // Store indegree of selected vertex before deletion
                history[k] = 0;

                visited[i] = 1;
                found = 1;

                for(int j = 0; j < n; j++)
                {
                    if(adj[i][j] == 1)
                        indegree[j]--;
                }

                // Count remaining zero indegree vertices
                int cnt = 0;
                for(int t = 0; t < n; t++)
                {
                    if(!visited[t] && indegree[t] == 0)
                        cnt++;
                }

                history[k] = cnt;
                k++;
            }
        }

        if(!found)
        {
            printf("\nGraph contains a cycle\n");
            return;
        }
    }

    printf("\nIndegree of given nodes\n\n");

    for(int i = 0; i < n; i++)
    {
        printf("%c = ", 'A' + i);

        for(int j = i; j >= 0; j--)
        {
            printf("%d ", history[j]);
        }

        printf("\n\n");
    }

    printf("Topological Order is ");

    for(int i = 0; i < n; i++)
    {
        printf("%c ", 'A' + topo[i]);
    }

    printf("\n");
}

int main()
{
    int n;
    int adj[20][20];

    clock_t start, end;
    double cpu_time;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter Adjacency Matrix:\n");

    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < n; j++)
        {
            scanf("%d", &adj[i][j]);
        }
    }

    start = clock();

    topologicalSort(n, adj);

    end = clock();

    cpu_time = (double)(end - start) / CLOCKS_PER_SEC;

    printf("\nTime Taken = %f seconds\n", cpu_time);
    printf("Time Complexity = O(n^2)\n");

    return 0;
}
