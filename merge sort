#include <stdio.h>
#include <stdlib.h>
#include <time.h>

void merge(int a[], int l, int m, int r)
{
    int n1 = m - l + 1;
    int n2 = r - m;

    int L[n1], R[n2];

    for(int i = 0; i < n1; i++)
        L[i] = a[l + i];

    for(int j = 0; j < n2; j++)
        R[j] = a[m + 1 + j];

    int i = 0, j = 0, k = l;

    while(i < n1 && j < n2)
    {
        if(L[i] <= R[j])
            a[k++] = L[i++];
        else
            a[k++] = R[j++];
    }

    while(i < n1)
        a[k++] = L[i++];

    while(j < n2)
        a[k++] = R[j++];
}

void mergeSort(int a[], int l, int r)
{
    if(l < r)
    {
        int m = (l + r) / 2;

        mergeSort(a, l, m);
        mergeSort(a, m + 1, r);

        merge(a, l, m, r);
    }
}

int main()
{
    printf("\nMerge Sort Analysis\n\n");

    printf("---------------------------------------------------------------\n");
    printf("Size\tAscending\tDescending\tRandom\n");
    printf("---------------------------------------------------------------\n");

    for(int n = 1000; n <= 10000; n += 1000)
    {
        int asc[n];
        int desc[n];
        int randArr[n];

        for(int i = 0; i < n; i++)
        {
            asc[i] = i;
            desc[i] = n - i;
            randArr[i] = rand() % 10000;
        }

        clock_t start, end;

        start = clock();
        mergeSort(asc, 0, n - 1);
        end = clock();
        double ascTime = (double)(end - start) / CLOCKS_PER_SEC;

        start = clock();
        mergeSort(desc, 0, n - 1);
        end = clock();
        double descTime = (double)(end - start) / CLOCKS_PER_SEC;

        start = clock();
        mergeSort(randArr, 0, n - 1);
        end = clock();
        double randTime = (double)(end - start) / CLOCKS_PER_SEC;

        printf("%d\t%.6f\t%.6f\t%.6f\n",
               n, ascTime, descTime, randTime);
    }

    printf("---------------------------------------------------------------\n");

    return 0;
}
